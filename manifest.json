{
  "manifest_version": 3,
  "name": "百度优化插件",
  "version": "1.0",
  "description": "优化百度搜索结果",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/enabled16.png",
      "32": "icons/enabled32.png",
      "48": "icons/enabled48.png",
      "64": "icons/enabled64.png",
      "128": "icons/enabled128.png"
    }
  },
  "icons":{
    "16": "icons/enabled16.png",
    "32": "icons/enabled32.png",
    "48": "icons/enabled48.png",
    "64": "icons/enabled64.png",
    "128": "icons/enabled128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://www.baidu.com/s*"],
      "css":["content/content_css.css"],
      "js": ["content/main.js", "default_var.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.baidu.com/s*"],
      "js": ["content/delete_tn.js", "default_var.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://www.baidu.com/s*"],
      "js": ["content/order_left.js", "default_var.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://www.baidu.com/s*"],
      "js": ["content/group_right.js", "default_var.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "options_ui": {
    "page": "setting/setting.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage"
  ]
}